{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with premium status and expiration date.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "description": "User's email address" },
        "isPremium": { "type": "boolean", "description": "Whether the user has premium access" },
        "premiumExpiration": { "type": "string", "format": "date", "description": "ISO date string for premium expiration" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" }
      },
      "required": ["uid", "email", "isPremium", "role"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction (income or expense)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string", "description": "Owner's UID" },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "amount", "type", "category", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User financial transactions"
    }
  }
}
